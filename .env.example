# Vision provider: gemini | openai | anthropic
VISION_PROVIDER=anthropic

# Vision model — omit to use the default for your provider:
#   anthropic → claude-haiku-4-5
#   openai    → gpt-5.4-mini
#   gemini    → gemini-2.5-flash
VISION_MODEL=claude-haiku-4-5

# API keys — only the key for your chosen provider is required
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# USDA FoodData Central — get a free key at https://fdc.nal.usda.gov/api-guide.html
# Rate limit: 1000 req/hour/IP. Omit to use DEMO_KEY (very limited).
USDA_API_KEY=

# PostgreSQL connection string (used by Prisma)
DATABASE_URL=postgresql://user:password@localhost:5432/macrosnap

PORT=3000
